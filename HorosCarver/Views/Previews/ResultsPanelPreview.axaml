<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HorosCarver.ViewModels.Previews"
        xmlns:components="using:HorosCarver.Views.Components"
        x:Class="HorosCarver.Views.Previews.ResultsPanelPreview"
        x:DataType="vm:ResultsPanelPreviewViewModel"
        Title="Preview: R04 Ergebnis-Panel"
        Width="360"
        Height="640"
        Background="{DynamicResource BrushBackgroundBase}">

    <components:HorosResultsPanel DataContext="{Binding Results}" />

</Window>
