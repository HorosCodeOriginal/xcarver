<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HorosCarver.ViewModels.Previews"
        xmlns:components="using:HorosCarver.Views.Components"
        x:Class="HorosCarver.Views.Previews.ScanOptionsPanelPreview"
        x:DataType="vm:ScanOptionsPanelPreviewViewModel"
        Title="Preview: R03 Scan-Optionen"
        Width="720"
        Height="560"
        Background="{DynamicResource BrushBackgroundBase}"
        Padding="24">

    <components:HorosScanOptionsPanel DataContext="{Binding Scan}" />

</Window>
