<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- HorosCode / HorosCarver — extracted from Clean Mockup -->
    <Color x:Key="ColorBackgroundBase">#FF1A1D23</Color>
    <Color x:Key="ColorSurfaceDefault">#FF1F232B</Color>
    <Color x:Key="ColorSurfaceElevated">#FF252A33</Color>
    <Color x:Key="ColorBorderDefault">#FF2D3340</Color>
    <Color x:Key="ColorAccentPrimary">#FF00BCD4</Color>
    <Color x:Key="ColorAccentSuccess">#FF4CAF50</Color>
    <Color x:Key="ColorTextPrimary">#FFE8EAED</Color>
    <Color x:Key="ColorTextMuted">#FF9AA0A6</Color>
    <Color x:Key="ColorNavActiveBg">#FF1E2A32</Color>
    <Color x:Key="ColorError">#FFE57373</Color>

    <SolidColorBrush x:Key="BrushBackgroundBase" Color="{StaticResource ColorBackgroundBase}" />
    <SolidColorBrush x:Key="BrushNavActiveBg" Color="{StaticResource ColorNavActiveBg}" />
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}" />
    <SolidColorBrush x:Key="BrushSurfaceDefault" Color="{StaticResource ColorSurfaceDefault}" />
    <SolidColorBrush x:Key="BrushSurfaceElevated" Color="{StaticResource ColorSurfaceElevated}" />
    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource ColorBorderDefault}" />
    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource ColorAccentPrimary}" />
    <SolidColorBrush x:Key="BrushAccentSuccess" Color="{StaticResource ColorAccentSuccess}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />

    <Thickness x:Key="Spacing2">8</Thickness>
    <Thickness x:Key="Spacing3">12</Thickness>
    <Thickness x:Key="Spacing4">16</Thickness>
    <Thickness x:Key="Spacing6">24</Thickness>

    <x:Double x:Key="SidebarWidth">240</x:Double>
    <x:Double x:Key="ResultsPanelWidth">320</x:Double>
    <x:Double x:Key="FontSizeNav">14</x:Double>
    <x:Double x:Key="FontSizeBrand">13</x:Double>
    <x:Double x:Key="FontSizeAppTitle">11</x:Double>
    <x:Double x:Key="FontSizeStatus">12</x:Double>
    <x:Double x:Key="NavItemHeight">40</x:Double>
    <x:Double x:Key="StatusBarHeight">28</x:Double>
    <x:Double x:Key="DropZoneMinHeight">160</x:Double>
    <x:Double x:Key="FontSizeSectionTitle">16</x:Double>
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>

</ResourceDictionary>
